ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=lib3dgrt_cc -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1018\" -I/usr/local/cuda/targets/x86_64-linux/include -I/home/ubuntu/Code/3dgrut-port/threedgrt_tracer/include -I/home/ubuntu/Code/3dgrut-port/threedgrt_tracer/dependencies/optix-dev/include -isystem /home/ubuntu/Code/Hax-CV-wt-trainable-sfm/.venv/lib/python3.12/site-packages/torch/include -isystem /home/ubuntu/Code/Hax-CV-wt-trainable-sfm/.venv/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /home/ubuntu/.local/share/uv/python/cpython-3.12.13-linux-x86_64-gnu/include/python3.12 -fPIC -std=c++17 -DNVDR_TORCH -DPARTICLE_FEATURE_DIM=48 -DRAY_FEATURE_DIM=3 -DFEATURE_TRANSFORM_TYPE=0 -DPARTICLE_FEATURE_HALF=0 -DFEATURE_OUTPUT_HALF=0
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=lib3dgrt_cc -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1018\" -I/usr/local/cuda/targets/x86_64-linux/include -I/home/ubuntu/Code/3dgrut-port/threedgrt_tracer/include -I/home/ubuntu/Code/3dgrut-port/threedgrt_tracer/dependencies/optix-dev/include -isystem /home/ubuntu/Code/Hax-CV-wt-trainable-sfm/.venv/lib/python3.12/site-packages/torch/include -isystem /home/ubuntu/Code/Hax-CV-wt-trainable-sfm/.venv/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /home/ubuntu/.local/share/uv/python/cpython-3.12.13-linux-x86_64-gnu/include/python3.12 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_90,code=compute_90 -gencode=arch=compute_90,code=sm_90 --compiler-options '-fPIC' -DNVDR_TORCH -std=c++17 --extended-lambda --expt-relaxed-constexpr -Xcompiler=-fno-strict-aliasing -diag-suppress=1444 -diag-suppress=3287 -DPARTICLE_FEATURE_DIM=48 -DRAY_FEATURE_DIM=3 -DFEATURE_TRANSFORM_TYPE=0 -DFEATURE_INTERPOLATION_TYPE=0 -DFEATURE_INTERPOLATION_SUPPORT=0 -DFEATURE_ACTIVATION_TYPE=0 -DFEATURE_ACTIVATION_NUM_FREQUENCIES=1 -DINTERP_POINT_FEATURE_DIM=3 -DPARTICLE_FEATURE_HALF=0 -DFEATURE_OUTPUT_HALF=0 -DPARTICLE_RADIANCE_NUM_COEFFS=16 -DGAUSSIAN_PARTICLE_KERNEL_DEGREE=2 -DGAUSSIAN_PARTICLE_MIN_KERNEL_DENSITY=0.0113 -DGAUSSIAN_PARTICLE_MIN_ALPHA=0.00392156862745098 -DGAUSSIAN_PARTICLE_MAX_ALPHA=0.99 -DGAUSSIAN_MIN_TRANSMITTANCE_THRESHOLD=0.0001
cuda_post_cflags = 
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = -shared -L/usr/local/cuda/lib/stubs -L/usr/local/cuda/targets/x86_64-linux/lib -L/usr/local/cuda/targets/x86_64-linux/lib/stubs -lcuda -lnvrtc -L/home/ubuntu/Code/Hax-CV-wt-trainable-sfm/.venv/lib/python3.12/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





rule link
  command = $cxx $in $ldflags -o $out

build optixTracer.o: compile /home/ubuntu/Code/3dgrut-port/threedgrt_tracer/src/optixTracer.cpp
build particlePrimitives.cuda.o: cuda_compile /home/ubuntu/Code/3dgrut-port/threedgrt_tracer/src/particlePrimitives.cu
build bindings.o: compile /home/ubuntu/Code/3dgrut-port/threedgrt_tracer/bindings.cpp





build lib3dgrt_cc.so: link optixTracer.o particlePrimitives.cuda.o bindings.o

default lib3dgrt_cc.so
